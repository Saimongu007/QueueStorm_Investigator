# Secrets — never bake into the image (pass via env at runtime)
.env
.env.*
!.env.example

# Virtualenv / caches / build artifacts
venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# VCS / IDE / OS
.git/
.gitignore
.github/
.DS_Store
.puku/
.claude/

# Docs & problem-pack assets not needed at runtime
*.pdf
*.md
queuestorm_claude_code_prompt.md

# Tests are not needed in the runtime image
tests/
